# keystore.properties のサンプル。
# このファイルを keystore.properties にコピーして値を埋めてください（keystore.properties は gitignore 対象）。
# アップロード鍵(keystore)の作成例:
#   keytool -genkeypair -v -keystore upload-keystore.jks \
#     -alias upload -keyalg RSA -keysize 2048 -validity 10000
storeFile=upload-keystore.jks
storePassword=ここに変更
keyAlias=upload
keyPassword=ここに変更
